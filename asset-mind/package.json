{
  "name": "assetmind-design-system",
  "version": "1.0.0",
  "description": "AssetMind Design System - React component library and design tokens built with Tailwind CSS",
  "keywords": [
    "design-system",
    "react",
    "storybook",
    "tailwindcss",
    "typescript",
    "components",
    "ui-library"
  ],
  "author": "AssetMind",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ASSETMIND"
  },
  "homepage": "https://your-storybook-url.vercel.app",
  "bugs": {
    "url": "https://github.com/ASSETMIND"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --disable-telemetry",
    "qa:a11y": "node scripts/a11y-test.js",
    "qa:build": "npm run build-storybook",
    "qa:serve": "npx http-server storybook-static -p 8080",
    "qa:full": "npm run qa:build && npm run qa:serve"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@eslint/js": "^9.39.1",
    "@storybook/addon-a11y": "^10.2.5",
    "@storybook/addon-docs": "^10.2.5",
    "@storybook/addon-vitest": "^10.2.5",
    "@storybook/react-vite": "^10.2.5",
    "@types/node": "^24.10.1",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.5",
    "globals": "^16.5.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "storybook": "^10.2.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.11",
    "vitest": "^4.0.17"
  }

  
}
